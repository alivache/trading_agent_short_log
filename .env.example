# ═══════════════════════════════════════
# CONFIGURARE AGENT TRADING V2
# Copiaza acest fisier in .env si completeaza cheile tale
# ═══════════════════════════════════════

# Chei Alpaca (paper trading)
APCA_API_KEY_ID=cheia_ta_paper
APCA_API_SECRET_KEY=secretul_tau_paper
APCA_BASE_URL=https://paper-api.alpaca.markets

# Limite de risc
MAX_POZITIE_PCT=5
STOP_LOSS_PCT=8
REZERVA_CASH_PCT=20
EXPUNERE_MAX_PCT=80
LIMIT_ORDER_MARJA_PCT=0.2

# Setari generale
MAX_TRADES_PER_ZI=5
